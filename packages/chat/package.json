{
  "name": "@behayand/chat",
  "version": "0.1.0",
  "description": "Behayand Chat - A reusable Vue 3 chat component library",
  "type": "module",
  "main": "./dist/behayand-chat.umd.cjs",
  "module": "./dist/behayand-chat.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/behayand-chat.js",
      "require": "./dist/behayand-chat.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "pinia": "^2.0.0 || ^3.0.0",
    "vue": "^3.3.0"
  },
  "dependencies": {
    "@phosphor-icons/vue": "^2.2.1",
    "@tanstack/vue-virtual": "^3.13.24",
    "@vueuse/core": "^14.2.1",
    "vue3-lottie": "^3.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.4.0",
    "vite": "^6.4.2",
    "vite-plugin-dts": "^4.0.0",
    "vue-tsc": "^2.0.0"
  }
}
