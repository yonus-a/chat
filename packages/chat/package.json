{
  "name": "@behayand/chat",
  "version": "0.1.0",
  "description": "Reusable chat UI module with pluggable data adapter",
  "type": "module",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "vue": "^3.5.31",
    "vue-tsc": "^2.2.0",
    "vite": "^6.3.5",
    "typescript": "^5.8.3",
    "@vitejs/plugin-vue": "^5.2.4"
  },
  "license": "MIT"
}
