{
  "name": "@behayand/chat",
  "version": "0.1.0",
  "description": "Behayand Chat UI package with adapter pattern for data injection",
  "type": "module",
  "main": "./dist/behayand-chat.umd.cjs",
  "module": "./dist/behayand-chat.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/behayand-chat.js",
      "require": "./dist/behayand-chat.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly --declaration --outDir dist",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^6.3.0",
    "vue": "^3.5.31",
    "vue-tsc": "^2.2.0"
  }
}
