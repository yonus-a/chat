{
  "name": "@behayand/chat",
  "version": "0.1.0",
  "description": "Behayand Chat - Standalone Vue 3 chat module with theming and data adapter support",
  "type": "module",
  "main": "./dist/behayand-chat.umd.cjs",
  "module": "./dist/behayand-chat.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/behayand-chat.js",
      "require": "./dist/behayand-chat.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "pinia": "^2.0.0 || ^3.0.0"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@phosphor-icons/vue": "^2.2.1",
    "@tanstack/vue-virtual": "^3.13.24",
    "@twemoji/api": "^17.0.2",
    "@vueuse/core": "^14.2.1",
    "emoji-mart": "^5.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.4.2",
    "vite-plugin-dts": "^4.0.0",
    "vue": "^3.5.31",
    "vue-tsc": "^2.0.0",
    "pinia": "^3.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yonus-a/behayand"
  }
}
